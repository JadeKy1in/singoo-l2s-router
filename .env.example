# Singoo L2S-Router Configuration
# Copy to .env and fill in values for production runs

# LLM Provider
SINGOO_LLM_BASE_URL=http://localhost:8000/v1
SINGOO_LLM_API_KEY=sk-your-key-here

# Models (can override per agent)
SINGOO_ROUTER_MODEL=mock
SINGOO_SALES_MODEL=mock
SINGOO_EXTRACTOR_MODEL=mock

# RAG
SINGOO_RAG_DOCS_PATH=data/knowledge
SINGOO_RAG_COLLECTION_NAME=singoo_products

# Storage
SINGOO_THREAD_STORE_DIR=data/threads

# Server
SINGOO_HOST=127.0.0.1
SINGOO_PORT=8000

# Pipeline
SINGOO_MAX_TURNS=5
SINGOO_MOCK_MODE=true
